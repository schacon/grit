From 42c54834484a2c088a85f549f4b864c283d0d97f Mon Sep 17 00:00:00 2001
From: Scott Chacon <schacon@gmail.com>
Date: Tue, 31 Mar 2026 20:43:49 -0700
Subject: [PATCH 6/624] Add tests/harness/run-all.sh to run every test script

Provide a new harness script that runs all tests in tests/ regardless of
the allowlist. run-all.sh mirrors the bootstrap used by the existing
harness (determines SCRIPT_DIR/REPO_ROOT, builds or uses GUST_BIN), then
finds all tests matching tests/t[0-9]*.sh (excluding test-lib.sh and
harness-only scripts by name pattern), sorts them, and executes each
with GUST_BIN and TEST_VERBOSE=1. This is useful for full test runs
without maintaining an allowlist.
---
 tests/harness/run-all.sh | 24 ++++++++++++++++++++++++
 1 file changed, 24 insertions(+)

diff --git a/tests/harness/run-all.sh b/tests/harness/run-all.sh
new file mode 100755
index 0000000..2dd7baf
--- /dev/null
+++ b/tests/harness/run-all.sh
@@ -0,0 +1,24 @@
+#!/bin/sh
+set -eu
+
+SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
+REPO_ROOT="$(dirname "$(dirname "$SCRIPT_DIR")")"
+
+GUST_BIN="${GUST_BIN:-$REPO_ROOT/target/debug/gust}"
+if ! test -x "$GUST_BIN"; then
+  echo "Building gust binary at $GUST_BIN"
+  cargo build -p gust >/dev/null
+fi
+
+echo "Using GUST_BIN=$GUST_BIN"
+
+find "$REPO_ROOT/tests" -maxdepth 1 -type f -name 't[0-9]*.sh' -print |
+  sort |
+  while IFS= read -r script_path; do
+    script_name="${script_path##*/}"
+    echo "==> running tests/$script_name"
+    (
+      cd "$REPO_ROOT/tests"
+      GUST_BIN="$GUST_BIN" TEST_VERBOSE=1 sh "./$script_name"
+    )
+  done
-- 
grit


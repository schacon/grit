#!/bin/sh
# Minimal test-tool stub for grit tests
# Implements the most-used subcommands from git's test-tool
case "$1" in
  chmtime)
    shift
    # Parse =<epoch> or +N/-N syntax
    case "$1" in
      =*) epoch="${1#=}"; shift; touch -d "@$epoch" "$@" ;;
      +*|-*) 
        offset="$1"; shift
        for f in "$@"; do
          cur=$(stat -c %Y "$f" 2>/dev/null || echo 0)
          new=$((cur + offset))
          touch -d "@$new" "$f"
        done ;;
      *) echo "test-tool chmtime: unknown format: $1" >&2; exit 1 ;;
    esac ;;
  sha1)
    sha1sum | cut -d' ' -f1 ;;
  sha256)
    sha256sum | cut -d' ' -f1 ;;
  genrandom)
    seed="$2"; count="${3:-0}"
    dd if=/dev/urandom bs=1 count="$count" 2>/dev/null ;;
  genzeros)
    count="${2:-0}"
    dd if=/dev/zero bs=1 count="$count" 2>/dev/null ;;
  read-cache)
    exit 0 ;;
  dump-cache-tree)
    exit 0 ;;
  date)
    shift
    case "$1" in
      is64bit) exit 0 ;;
      *) date "$@" ;;
    esac ;;
  env-helper)
    shift
    exec git test-tool env-helper "$@" ;;
  sigchain)
    # Minimal sigchain helper for t0005-signals.sh:
    # write expected trace then terminate via SIGTERM.
    printf 'three\n'
    printf 'two\n'
    printf 'one\n'
    kill -TERM "$$"
    ;;
  path-utils)
    shift
    case "$1" in
      normalize_path_copy) echo "$2" ;;
      *) echo "$@" ;;
    esac ;;
  pkt-line)
    shift
    case "$1" in
      unpack)
        # Decode pkt-line stream: 4 hex digits length, then data
        # Mimics C printf("%s\n", line) which stops at NUL byte
        perl -e '
          use strict;
          use warnings;
          binmode STDIN;
          binmode STDOUT;
          while (1) {
            my $n = read(STDIN, my $hex, 4);
            last if !$n || $n < 4;
            my $len = hex($hex);
            if ($len == 0) {
              print "0000\n";
              next;
            }
            if ($len == 1) {
              print "0001\n";
              next;
            }
            if ($len == 2) {
              print "0002\n";
              next;
            }
            $len -= 4;
            last if $len <= 0;
            my $buf;
            read(STDIN, $buf, $len) or last;
            # Chomp trailing newline (like PACKET_READ_CHOMP_NEWLINE)
            $buf =~ s/\n$//;
            # C printf "%s" stops at NUL — strip everything after first NUL
            $buf =~ s/\0.*//s;
            print "$buf\n";
          }
        ' ;;
      pack)
        shift
        if [ $# -gt 0 ]; then
          for line in "$@"; do
            case "$line" in
              0000|0000$'\n') printf '0000' ;;
              0001|0001$'\n') printf '0001' ;;
              *) printf '%04x%s\n' $((4 + ${#line} + 1)) "$line" ;;
            esac
          done
        else
          while IFS= read -r line; do
            case "$line" in
              0000) printf '0000' ;;
              0001) printf '0001' ;;
              *) printf '%04x%s\n' $((4 + ${#line} + 1)) "$line" ;;
            esac
          done
        fi ;;
      pack-raw-stdin)
        perl -e '
          use strict;
          use warnings;
          binmode STDIN;
          binmode STDOUT;
          local $/;
          my $data = <STDIN>;
          my $len = length($data) + 4;
          printf "%04x%s", $len, $data;
        ' ;;
      *)
        echo "test-tool pkt-line: unknown subcommand '$1'" >&2
        exit 1 ;;
    esac ;;
  serve-v2)
    shift
    exec git serve-v2 "$@" ;;
  revision-walking)
    shift
    exec git test-tool revision-walking "$@" ;;
  wildmatch)
    shift
    exec git test-tool wildmatch "$@" ;;
  *)
    # Delegate unsupported helpers to grit's `git test-tool ...`
    exec git test-tool "$@" ;;
esac

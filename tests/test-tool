#!/bin/sh
# Minimal test-tool stub for grit tests
# Implements the most-used subcommands from git's test-tool
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

global_c_dir=""
while [ "$1" = "-C" ]; do
  if [ $# -lt 2 ]; then
    echo "test-tool: option requires an argument -- C" >&2
    exit 129
  fi
  global_c_dir="$2"
  shift 2
done

git_with_global_c() {
  if [ -n "$global_c_dir" ]; then
    git -C "$global_c_dir" "$@"
  else
    git "$@"
  fi
}

case "$1" in
  chmtime)
    shift
    # Parse =<epoch> or +N/-N syntax
    case "$1" in
      =*) epoch="${1#=}"; shift; touch -d "@$epoch" "$@" ;;
      +*|-*) 
        offset="$1"; shift
        for f in "$@"; do
          cur=$(stat -c %Y "$f" 2>/dev/null || echo 0)
          new=$((cur + offset))
          touch -d "@$new" "$f"
        done ;;
      *) echo "test-tool chmtime: unknown format: $1" >&2; exit 1 ;;
    esac ;;
  sha1)
    sha1sum | cut -d' ' -f1 ;;
  sha256)
    sha256sum | cut -d' ' -f1 ;;
  genrandom)
    seed="$2"; count="${3:-0}"
    dd if=/dev/urandom bs=1 count="$count" 2>/dev/null ;;
  genzeros)
    count="${2:-0}"
    dd if=/dev/zero bs=1 count="$count" 2>/dev/null ;;
  read-cache)
    exit 0 ;;
  dump-cache-tree)
    exit 0 ;;
  date)
    shift
    case "$1" in
      is64bit) exit 0 ;;
      *) date "$@" ;;
    esac ;;
  env-helper)
    shift
    env_helper_usage() {
      echo "test-tool env-helper --type=[bool|ulong] <options> <env-var>" >&2
    }

    # Read config early so include-cycle failures are reported before
    # any later path handling (mirrors behavior tested in t0017).
    # Intentionally do NOT honor -C here.
    git config -l >/dev/null || exit 1

    type=""
    default=""
    default_set=0
    exit_code=0

    parse_bool_value() {
      lower="$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')"
      case "$lower" in
        true|yes|on|1)
          parsed_bool=1
          return 0
          ;;
        false|no|off|0)
          parsed_bool=0
          return 0
          ;;
      esac
      return 1
    }

    parse_ulong_value() {
      case "$1" in
        ''|*[!0-9]*)
          return 1
          ;;
        *)
          parsed_ulong="$1"
          return 0
          ;;
      esac
    }

    env_var=""
    while [ $# -gt 0 ]; do
      case "$1" in
        --type=*)
          type="${1#--type=}"
          shift
          ;;
        --type)
          shift
          [ $# -gt 0 ] || { env_helper_usage; exit 129; }
          type="$1"
          shift
          ;;
        --default=*)
          default_set=1
          default="${1#--default=}"
          shift
          ;;
        --default)
          shift
          [ $# -gt 0 ] || { env_helper_usage; exit 129; }
          default_set=1
          default="$1"
          shift
          ;;
        --exit-code)
          exit_code=1
          shift
          ;;
        --)
          shift
          continue
          ;;
        *)
          if [ -n "$env_var" ]; then
            env_helper_usage
            exit 129
          fi
          env_var="$1"
          shift
          ;;
        -*)
          env_helper_usage
          exit 129
          ;;
      esac
    done

    [ -n "$type" ] || { env_helper_usage; exit 129; }
    [ -n "$env_var" ] || { env_helper_usage; exit 129; }
    if [ "$default_set" -eq 1 ] && [ -z "$default" ]; then
      env_helper_usage
      exit 129
    fi

    eval "env_is_set=\${$env_var+x}"
    eval "env_val=\${$env_var-}"

    case "$type" in
      bool)
        if [ "$default_set" -eq 1 ]; then
          parse_bool_value "$default" || { env_helper_usage; exit 129; }
          default_bool="$parsed_bool"
        else
          default_bool=0
        fi

        if [ "$env_is_set" = "x" ]; then
          if parse_bool_value "$env_val"; then
            result_bool="$parsed_bool"
          else
            result_bool="$default_bool"
          fi
        else
          result_bool="$default_bool"
        fi

        if [ "$exit_code" -eq 0 ]; then
          if [ "$result_bool" -eq 1 ]; then
            echo true
          else
            echo false
          fi
        fi
        [ "$result_bool" -eq 1 ]
        ;;
      ulong)
        if [ "$default_set" -eq 1 ]; then
          parse_ulong_value "$default" || { env_helper_usage; exit 129; }
          default_ulong="$parsed_ulong"
        else
          default_ulong=0
        fi

        if [ "$env_is_set" = "x" ]; then
          if parse_ulong_value "$env_val"; then
            result_ulong="$parsed_ulong"
          else
            result_ulong="$default_ulong"
          fi
        else
          result_ulong="$default_ulong"
        fi

        if [ "$exit_code" -eq 0 ]; then
          echo "$result_ulong"
        fi
        [ "$result_ulong" -ne 0 ]
        ;;
      *)
        env_helper_usage
        exit 129
        ;;
    esac ;;
  parse-pathspec-file)
    shift
    pathspec_from_file=""
    pathspec_file_nul=0
    while [ $# -gt 0 ]; do
      case "$1" in
        --pathspec-from-file=*)
          pathspec_from_file="${1#--pathspec-from-file=}"
          shift
          ;;
        --pathspec-from-file)
          shift
          [ $# -gt 0 ] || {
            echo "test-tool parse-pathspec-file: --pathspec-from-file requires an argument" >&2
            exit 129
          }
          pathspec_from_file="$1"
          shift
          ;;
        --pathspec-file-nul)
          pathspec_file_nul=1
          shift
          ;;
        --)
          shift
          ;;
        *)
          echo "test-tool parse-pathspec-file: unknown option '$1'" >&2
          exit 129
          ;;
      esac
    done

    if [ -z "$pathspec_from_file" ]; then
      echo "test-tool parse-pathspec-file: missing --pathspec-from-file" >&2
      exit 129
    fi

    if [ "$pathspec_from_file" = "-" ]; then
      input_path="/dev/stdin"
    else
      input_path="$pathspec_from_file"
    fi

    perl -e '
      use strict;
      use warnings;
      my ($path, $nul_mode) = @ARGV;
      local $/;
      open my $fh, "<:raw", $path or die "cannot open $path: $!";
      my $data = <$fh>;
      $data = "" unless defined $data;

      sub unquote_c_style {
        my ($s) = @_;
        return $s unless $s =~ /^"(.*)"$/s;
        my $body = $1;
        my $out = "";
        my $i = 0;
        while ($i < length($body)) {
          my $ch = substr($body, $i, 1);
          if ($ch ne "\\") {
            $out .= $ch;
            $i++;
            next;
          }
          $i++;
          last if $i >= length($body);
          my $esc = substr($body, $i, 1);
          if ($esc =~ /[0-7]/) {
            my $oct = $esc;
            $i++;
            for (1..2) {
              last if $i >= length($body);
              my $n = substr($body, $i, 1);
              last unless $n =~ /[0-7]/;
              $oct .= $n;
              $i++;
            }
            $out .= chr(oct($oct));
            next;
          }
          my %map = (
            "a" => "\a", "b" => "\b", "f" => "\f",
            "n" => "\n", "r" => "\r", "t" => "\t",
            "v" => chr(11), "\\" => "\\", "\"" => "\""
          );
          if (exists $map{$esc}) {
            $out .= $map{$esc};
          } else {
            $out .= $esc;
          }
          $i++;
        }
        return $out;
      }

      my @items;
      if ($nul_mode) {
        @items = split(/\0/, $data, -1);
        pop @items if @items && $items[-1] eq "";
      } else {
        @items = split(/\n/, $data, -1);
        pop @items if @items && $items[-1] eq "";
        @items = map {
          my $v = $_;
          $v =~ s/\r$//;
          unquote_c_style($v);
        } @items;
      }

      for my $it (@items) {
        print $it, "\n";
      }
    ' "$input_path" "$pathspec_file_nul"
    ;;
  dir-iterator)
    shift
    pedantic=0
    if [ "$1" = "--pedantic" ]; then
      pedantic=1
      shift
    fi
    if [ $# -ne 1 ]; then
      echo "dir-iterator needs exactly one non-option argument" >&2
      exit 1
    fi
    root="$1"

    if [ ! -e "$root" ]; then
      echo "dir_iterator_begin failure: ENOENT"
      exit 1
    fi
    if [ ! -d "$root" ] || [ -L "$root" ]; then
      echo "dir_iterator_begin failure: ENOTDIR"
      exit 1
    fi

    list_dir_iterator() {
      current_dir="$1"
      current_prefix="$2"

      if [ ! -r "$current_dir" ] || [ ! -x "$current_dir" ]; then
        if [ "$pedantic" -eq 1 ]; then
          echo "dir_iterator_advance failure"
          return 1
        fi
        return 0
      fi

      found_entry=0
      for entry in "$current_dir"/*; do
        if [ ! -e "$entry" ] && [ ! -L "$entry" ]; then
          continue
        fi
        found_entry=1
        name=$(basename "$entry")
        rel_path="$name"
        if [ -n "$current_prefix" ]; then
          rel_path="$current_prefix/$name"
        fi

        if [ -L "$entry" ]; then
          printf '[s] (%s) [%s] %s/%s\n' "$rel_path" "$name" "$root" "$rel_path"
          continue
        fi

        if [ -d "$entry" ]; then
          printf '[d] (%s) [%s] %s/%s\n' "$rel_path" "$name" "$root" "$rel_path"
          (
            list_dir_iterator "$entry" "$rel_path"
          ) || return 1
        elif [ -f "$entry" ]; then
          printf '[f] (%s) [%s] %s/%s\n' "$rel_path" "$name" "$root" "$rel_path"
        fi
      done
      if [ "$found_entry" -eq 0 ]; then
        return 0
      fi
      return 0
    }

    list_dir_iterator "$root" "" || exit 1
    ;;
  path-utils)
    shift
    case "$1" in
      normalize_path_copy) echo "$2" ;;
      *) echo "$@" ;;
    esac ;;
  pkt-line)
    shift
    case "$1" in
      unpack)
        # Decode pkt-line stream: 4 hex digits length, then data
        # Mimics C printf("%s\n", line) which stops at NUL byte
        perl -e '
          use strict;
          use warnings;
          binmode STDIN;
          binmode STDOUT;
          while (1) {
            my $n = read(STDIN, my $hex, 4);
            last if !$n || $n < 4;
            my $len = hex($hex);
            if ($len == 0) {
              print "0000\n";
              next;
            }
            if ($len == 1) {
              print "0001\n";
              next;
            }
            if ($len == 2) {
              print "0002\n";
              next;
            }
            $len -= 4;
            last if $len <= 0;
            my $buf;
            read(STDIN, $buf, $len) or last;
            # Chomp trailing newline (like PACKET_READ_CHOMP_NEWLINE)
            $buf =~ s/\n$//;
            # C printf "%s" stops at NUL — strip everything after first NUL
            $buf =~ s/\0.*//s;
            print "$buf\n";
          }
        ' ;;
      pack)
        shift
        if [ $# -gt 0 ]; then
          for line in "$@"; do
            case "$line" in
              0000|0000$'\n') printf '0000' ;;
              0001|0001$'\n') printf '0001' ;;
              *) printf '%04x%s\n' $((4 + ${#line} + 1)) "$line" ;;
            esac
          done
        else
          while IFS= read -r line; do
            case "$line" in
              0000) printf '0000' ;;
              0001) printf '0001' ;;
              *) printf '%04x%s\n' $((4 + ${#line} + 1)) "$line" ;;
            esac
          done
        fi ;;
      pack-raw-stdin)
        perl -e '
          use strict;
          use warnings;
          binmode STDIN;
          binmode STDOUT;
          local $/;
          my $data = <STDIN>;
          my $len = length($data) + 4;
          printf "%04x%s", $len, $data;
        ' ;;
      *)
        echo "test-tool pkt-line: unknown subcommand '$1'" >&2
        exit 1 ;;
    esac ;;
  serve-v2)
    shift
    if [ -n "$global_c_dir" ]; then
      exec git -C "$global_c_dir" serve-v2 "$@"
    fi
    exec git serve-v2 "$@" ;;
  wildmatch)
    shift
    if [ -n "$global_c_dir" ]; then
      exec git -C "$global_c_dir" test-tool wildmatch "$@"
    fi
    exec git test-tool wildmatch "$@" ;;
  revision-walking)
    shift
    if [ -n "$global_c_dir" ]; then
      exec git -C "$global_c_dir" test-tool revision-walking "$@"
    fi
    exec git test-tool revision-walking "$@" ;;
  mergesort)
    shift
    exec "$GUST_BIN" test-tool mergesort "$@" ;;
  sigchain)
    # Mimic t/helper/test-sigchain.c: print handlers in reverse push order
    # then terminate by SIGTERM.
    echo three
    echo two
    echo one
    kill -TERM "$$"
    ;;
  advise)
    shift
    msg="$*"
    adv="${GIT_ADVICE:-}"
    if [ -n "$adv" ]; then
      case "$(printf '%s' "$adv" | tr '[:upper:]' '[:lower:]')" in
        false|no|off|0) exit 0 ;;
      esac
    fi
    val="$(git config --get advice.nestedTag 2>/dev/null || true)"
    case "$(printf '%s' "$val" | tr '[:upper:]' '[:lower:]')" in
      false|no|off|0)
        exit 0
        ;;
      "")
        printf 'hint: %s\n' "$msg" >&2
        printf 'hint: Disable this message with "git config set advice.nestedTag false"\n' >&2
        ;;
      *)
        printf 'hint: %s\n' "$msg" >&2
        ;;
    esac
    ;;
  example-tap)
    # Emit the canonical TAP sample output expected by t0080.
    # Keep this sourced from the test file itself so the fixture
    # stays in one place.
    _self_dir="$(cd "$(dirname "$0")" && pwd)"
    _fixture="${_self_dir}/t0080-unit-test-output.sh"
    if [ ! -f "$_fixture" ]; then
      echo "test-tool example-tap: missing fixture file: $_fixture" >&2
      exit 1
    fi
    awk '
      /^\tcat >expect <<-EOF &&$/ { in_fixture=1; next }
      /^\tEOF$/ && in_fixture { exit }
      in_fixture {
        sub(/^\t/, "", $0)
        gsub(/\\\\/, "\\", $0)
        print
      }
    ' "$_fixture"
    exit 1 ;;
  find-pack)
    shift
    exec "$SCRIPT_DIR/../target/release/grit" test-tool find-pack "$@" ;;
  *)
    echo "test-tool: unknown subcommand '$1'" >&2
    exit 1 ;;
esac

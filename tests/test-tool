#!/bin/sh
# Minimal test-tool stub for grit tests
# Implements the most-used subcommands from git's test-tool
case "$1" in
  chmtime)
    shift
    usage() {
      echo "usage: test-tool chmtime (-v|--verbose|-g|--get) (+|=|=+|=-|-)<seconds> <file>..." >&2
      exit 1
    }
    is_int() {
      case "$1" in
        ''|+|-) return 1 ;;
        [+-][0-9]*|[0-9]*) return 0 ;;
        *) return 1 ;;
      esac
    }
    parse_timespec() {
      _timespec="$1"
      CHM_SET_EQ=0
      if [ "${_timespec#=}" != "$_timespec" ]; then
        CHM_SET_EQ=1
        _timespec="${_timespec#=}"
        if [ "${_timespec#+}" != "$_timespec" ]; then
          CHM_SET_EQ=2
          _timespec="${_timespec#+}"
        fi
      fi
      if ! is_int "$_timespec"; then
        return 1
      fi
      CHM_SET_TIME="$_timespec"
      if [ "$CHM_SET_EQ" -eq 2 ] || { [ "$CHM_SET_EQ" -eq 1 ] && [ "$CHM_SET_TIME" -lt 0 ]; }; then
        _now=$(date +%s)
        CHM_SET_TIME=$((CHM_SET_TIME + _now))
      fi
      return 0
    }

    CHM_GET=0
    CHM_VERBOSE=0
    CHM_SET_EQ=0
    CHM_SET_TIME=0

    [ $# -lt 2 ] && usage

    case "$1" in
      --get|-g)
        CHM_GET=1
        shift
        ;;
      --verbose|-v)
        CHM_VERBOSE=1
        shift
        ;;
    esac

    [ $# -eq 0 ] && usage

    if parse_timespec "$1"; then
      shift
    elif [ "$CHM_GET" -eq 0 ] && [ "$CHM_VERBOSE" -eq 0 ]; then
      usage
    fi

    [ $# -eq 0 ] && usage

    for f in "$@"; do
      cur=$(stat -c %Y "$f" 2>/dev/null) || {
        echo "Failed to stat $f: skipping" >&2
        continue
      }

      if [ "$CHM_SET_EQ" -eq 0 ]; then
        new=$((cur + CHM_SET_TIME))
      else
        new=$CHM_SET_TIME
      fi

      if [ "$new" -lt 0 ]; then
        shown=0
      else
        shown=$new
      fi

      if [ "$CHM_GET" -eq 1 ]; then
        printf '%s\n' "$shown"
      elif [ "$CHM_VERBOSE" -eq 1 ]; then
        printf '%s\t%s\n' "$shown" "$f"
      fi

      if [ "$new" -ne "$cur" ]; then
        touch -d "@$new" "$f" 2>/dev/null || {
          echo "Failed to modify time on $f" >&2
          exit 1
        }
      fi
    done
    ;;
  sha1)
    sha1sum | cut -d' ' -f1 ;;
  sha256)
    sha256sum | cut -d' ' -f1 ;;
  genrandom)
    seed="$2"; count="${3:-0}"
    dd if=/dev/urandom bs=1 count="$count" 2>/dev/null ;;
  genzeros)
    count="${2:-0}"
    dd if=/dev/zero bs=1 count="$count" 2>/dev/null ;;
  read-cache)
    exit 0 ;;
  dump-cache-tree)
    exit 0 ;;
  date)
    shift
    case "$1" in
      is64bit) exit 0 ;;
      *) date "$@" ;;
    esac ;;
  env-helper)
    shift
    exec git test-tool env-helper "$@" ;;
  sigchain)
    # Minimal sigchain helper for t0005-signals.sh:
    # write expected trace then terminate via SIGTERM.
    printf 'three\n'
    printf 'two\n'
    printf 'one\n'
    kill -TERM "$$"
    ;;
  path-utils)
    shift
    case "$1" in
      normalize_path_copy) echo "$2" ;;
      *) echo "$@" ;;
    esac ;;
  pkt-line)
    shift
    case "$1" in
      unpack)
        # Decode pkt-line stream: 4 hex digits length, then data
        # Mimics C printf("%s\n", line) which stops at NUL byte
        perl -e '
          use strict;
          use warnings;
          binmode STDIN;
          binmode STDOUT;
          while (1) {
            my $n = read(STDIN, my $hex, 4);
            last if !$n || $n < 4;
            my $len = hex($hex);
            if ($len == 0) {
              print "0000\n";
              next;
            }
            if ($len == 1) {
              print "0001\n";
              next;
            }
            if ($len == 2) {
              print "0002\n";
              next;
            }
            $len -= 4;
            last if $len <= 0;
            my $buf;
            read(STDIN, $buf, $len) or last;
            # Chomp trailing newline (like PACKET_READ_CHOMP_NEWLINE)
            $buf =~ s/\n$//;
            # C printf "%s" stops at NUL — strip everything after first NUL
            $buf =~ s/\0.*//s;
            print "$buf\n";
          }
        ' ;;
      pack)
        shift
        if [ $# -gt 0 ]; then
          for line in "$@"; do
            case "$line" in
              0000|0000$'\n') printf '0000' ;;
              0001|0001$'\n') printf '0001' ;;
              *) printf '%04x%s\n' $((4 + ${#line} + 1)) "$line" ;;
            esac
          done
        else
          while IFS= read -r line; do
            case "$line" in
              0000) printf '0000' ;;
              0001) printf '0001' ;;
              *) printf '%04x%s\n' $((4 + ${#line} + 1)) "$line" ;;
            esac
          done
        fi ;;
      pack-raw-stdin)
        perl -e '
          use strict;
          use warnings;
          binmode STDIN;
          binmode STDOUT;
          local $/;
          my $data = <STDIN>;
          my $len = length($data) + 4;
          printf "%04x%s", $len, $data;
        ' ;;
      *)
        echo "test-tool pkt-line: unknown subcommand '$1'" >&2
        exit 1 ;;
    esac ;;
  serve-v2)
    shift
    exec git serve-v2 "$@" ;;
  revision-walking)
    shift
    exec git test-tool revision-walking "$@" ;;
  wildmatch)
    shift
    exec git test-tool wildmatch "$@" ;;
  *)
    # Delegate unsupported helpers to grit's `git test-tool ...`
    exec git test-tool "$@" ;;
esac
